rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all safety default-deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isThreadOwner(threadId) {
      return get(/databases/$(database)/documents/threads/$(threadId)).data.userId == request.auth.uid;
    }

    // Validate User Profiles
    function isValidUserProfile(data) {
      return data.displayName is string;
    }

    // Validate Chat Threads
    function isValidThread(data) {
      return data.id is string && data.id.size() <= 128
         && data.title is string && data.title.size() <= 300
         && data.userId == request.auth.uid
         && (!('isPinned' in data) || data.isPinned == null || data.isPinned is bool);
    }

    // Validate Chat Messages
    function isValidMessage(data) {
      return data.id is string && data.id.size() <= 128
         && data.role is string && (data.role == "user" || data.role == "assistant")
         && data.content is string && data.content.size() <= 50000
         && data.timestamp is string
         && (!('isError' in data) || data.isError == null || data.isError is bool)
         && (!('image' in data) || data.image == null || data.image is string)
         && (!('audio' in data) || data.audio == null || data.audio is string)
         && (!('feedback' in data) || data.feedback == null || data.feedback is string)
         && (!('isEdited' in data) || data.isEdited == null || data.isEdited is bool);
    }

    // USER COLLECTION RULES
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow delete: if isOwner(userId);
    }

    // THREADS COLLECTION RULES
    match /threads/{threadId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(threadId) && isValidThread(request.resource.data);
      allow update: if isSignedIn() && isValidId(threadId) && isValidThread(request.resource.data) && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // MESSAGES SUBCOLLECTION RULES
    match /threads/{threadId}/messages/{messageId} {
      allow get: if isSignedIn() && isThreadOwner(threadId);
      allow list: if isSignedIn() && isThreadOwner(threadId);
      allow create: if isSignedIn() && isThreadOwner(threadId) && isValidId(messageId) && isValidMessage(request.resource.data);
      allow update: if isSignedIn() && isThreadOwner(threadId) && isValidId(messageId) && isValidMessage(request.resource.data);
      allow delete: if isSignedIn() && isThreadOwner(threadId);
    }
  }
}
